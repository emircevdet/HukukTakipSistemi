@model List<HukukTakipWeb.Models.Musteri>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Müşteri Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold">Müşteri Yönetimi</h2>
        
    </div>

    <a href="/Musteri/Create" class="btn btn-success">
        + Yeni Müşteri Ekle
    </a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get" action="/Musteri">
            <div class="row g-2">
                <div class="col-md-10">
                    <input type="text"
                           name="arama"
                           class="form-control"
                           placeholder="Müşteri no, ad/unvan, soyad veya TCKN ara..." />
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-dark">
                        Ara
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <strong>Müşteri Listesi</strong>
    </div>

    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Müşteri No</th>
                    <th>Ad / Ünvan</th>
                    <th>Soyad</th>
                    <th>TCKN</th>
                    <th>Şehir</th>
                    <th>İlçe</th>
                    <th>Durum</th>
                    <th class="text-center" style="width: 180px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var musteri in Model)
                    {
                        <tr>
                            <td>@musteri.MusteriId</td>
                            <td>@musteri.MusteriNo</td>
                            <td>@musteri.AdUnvan</td>
                            <td>@musteri.BorcluSoyadi</td>
                            <td>@musteri.Tckn</td>
                            <td>@musteri.Sehir</td>
                            <td>@musteri.Ilce</td>
                            <td>
                                @if (musteri.HayattaMi)
                                {
                                    <span class="badge bg-success">Hayatta</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Hayatta Değil</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="/Musteri/Edit/@musteri.MusteriId" class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>

                                <a href="/Musteri/Delete/@musteri.MusteriId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bu müşteriyi silmek istediğine emin misin?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            Kayıtlı müşteri bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>