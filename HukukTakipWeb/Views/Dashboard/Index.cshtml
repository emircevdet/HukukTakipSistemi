@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="dashboard-page">

    <div class="dashboard-bg-logo"></div>

    <div class="dashboard-wrapper">

        <div class="logout-area">
            <a href="/Auth/Logout"
               class="btn btn-outline-danger px-4 py-2 fw-semibold shadow-sm">
                Çıkış Yap
            </a>
        </div>

        <div class="text-center mb-5">
            <h1 class="dashboard-title">Hukuk Takip Yönetim Sistemi</h1>
        </div>

        <div class="row g-4 justify-content-center">

            <div class="col-md-4 col-lg-3">
                <a href="/Musteri" class="dashboard-card">
                    <div class="card border-0">
                        <div class="card-body text-center">
                            <h4>Müşteri</h4>
                            <p>Müşteri kayıtları</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 col-lg-3">
                <a href="/Avukat" class="dashboard-card">
                    <div class="card border-0">
                        <div class="card-body text-center">
                            <h4>Avukat</h4>
                            <p>Avukat bilgileri</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 col-lg-3">
                <a href="/Urun" class="dashboard-card">
                    <div class="card border-0">
                        <div class="card-body text-center">
                            <h4>Ürün</h4>
                            <p>Ürün kayıtları</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 col-lg-3">
                <a href="/IcraTakip" class="dashboard-card">
                    <div class="card border-0">
                        <div class="card-body text-center">
                            <h4>İcra Takip</h4>
                            <p>İcra dosyaları</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 col-lg-3">
                <a href="/Ihtar" class="dashboard-card">
                    <div class="card border-0">
                        <div class="card-body text-center">
                            <h4>İhtar</h4>
                            <p>İhtar kayıtları</p>
                        </div>
                    </div>
                </a>
            </div>

        </div>

    </div>

</div>

<style>
    body {
        background: #f4f6fb;
        overflow-x: hidden;
    }

    .dashboard-page {
        position: relative;
        min-height: 78vh;
        overflow: hidden;
    }

   

    

    .dashboard-wrapper {
        position: relative;
        z-index: 2;

        min-height: 70vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-top: 25px;
    }

    .logout-area {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 25px;
    }

    .dashboard-title {
        font-size: 42px;
        font-weight: 800;
        color: #111827;
        text-shadow: 0 2px 4px rgba(0,0,0,0.12);
    }

    .dashboard-card {
        text-decoration: none;
        color: #212529;
        display: block;
    }

    .dashboard-card .card {
        height: 150px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: 0.25s ease;
    }

    .dashboard-card .card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 28px rgba(0,0,0,0.15);
    }

    .dashboard-card h4 {
        color: #0d6efd;
        font-weight: 800;
        margin-top: 18px;
    }

    .dashboard-card p {
        color: #6c757d;
        margin-bottom: 0;
    }
</style>