@model List<HukukTakipWeb.Models.Ihtar>

@{
    ViewData["Title"] = "İhtar Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold">İhtar Yönetimi</h2>
    </div>

    <a href="/Ihtar/Create" class="btn btn-success">
        + Yeni İhtar Ekle
    </a>
</div>

<form method="get" action="/Ihtar" class="mb-4">
    <div class="input-group">
        <input type="text"
               name="arama"
               class="form-control"
               placeholder="Borçlu, ürün, noter adı, yevmiye no veya ihtar no ara..."
               value="@ViewBag.Arama" />

        <button class="btn btn-dark">Ara</button>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <strong>İhtar Listesi</strong>
    </div>

    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Borçlu</th>
                    <th>Ürün</th>
                    <th>Noter</th>
                    <th>Yevmiye No</th>
                    <th>İhtar Tarihi</th>
                    <th>Tebliğ Tarihi</th>
                    <th>İhtar No</th>
                    <th class="text-center" style="width:180px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var ihtar in Model)
                    {
                        <tr>
                            <td>@ihtar.IhtarId</td>
                            <td>@ihtar.Musteri?.AdUnvan</td>
                            <td>@ihtar.Urun?.UrunAdi</td>
                            <td>@ihtar.NoterAdi</td>
                            <td>@ihtar.YevmiyeNo</td>
                            <td>@ihtar.IhtarTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@ihtar.TebligTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@ihtar.IhtarNo</td>
                            <td class="text-center">
                                <a href="/Ihtar/Edit/@ihtar.IhtarId" class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>

                                <a href="/Ihtar/Delete/@ihtar.IhtarId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bu ihtarı silmek istediğine emin misin?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            Kayıtlı ihtar bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>