@model List<HukukTakipWeb.Models.IcraTakip>

@{
    ViewData["Title"] = "İcra Takip Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold">İcra Takip Yönetimi</h2>
        
    </div>

    <a href="/IcraTakip/Create" class="btn btn-success">
        + Yeni İcra Takip
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <strong>İcra Takip Listesi</strong>
    </div>

    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Borçlu</th>
                    <th>Ürün</th>
                    <th>Avukat</th>
                    <th>Takip Tarihi</th>
                    <th>Takip Tipi</th>
                    <th>Dosya No</th>
                    <th>İcra Müdürlüğü</th>
                    <th class="text-center" style="width:180px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IcraTakipId</td>
                            <td>@item.Musteri?.AdUnvan</td>
                            <td>@item.Urun?.UrunAdi</td>
                            <td>@item.Avukat?.Adi @item.Avukat?.Soyadi</td>
                            <td>@item.TakipTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@item.TakipTipi</td>
                            <td>@item.IcraDosyaYili / @item.IcraDosyaNo</td>
                            <td>@item.IcraMudurlugu</td>
                            <td class="text-center">
                                <a href="/IcraTakip/Edit/@item.IcraTakipId" class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>

                                <a href="/IcraTakip/Delete/@item.IcraTakipId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bu icra takip kaydını silmek istediğine emin misin?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            Kayıtlı icra takip bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>