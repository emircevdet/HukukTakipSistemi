@model List<HukukTakipWeb.Models.Urun>

@{
    ViewData["Title"] = "Ürün Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold">Ürün Yönetimi</h2>
        
    </div>

    <a href="/Urun/Create" class="btn btn-success">
        + Yeni Ürün Ekle
    </a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get" action="/Urun">
            <div class="row g-2">
                <div class="col-md-10">
                    <input type="text"
                           name="arama"
                           class="form-control"
                           placeholder="Ürün adı, mudi no, borçlu veya avukat ara..."
                           value="@ViewBag.Arama" />
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-dark">Ara</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <strong>Ürün Listesi</strong>
    </div>

    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Borçlu</th>
                    <th>Ürün Adı</th>
                    <th>Kredi Mudi No</th>
                    <th>Takip Miktarı</th>
                    <th>Döviz</th>
                    <th>Takip Tarihi</th>
                    <th>Avukat</th>
                    <th class="text-center" style="width:180px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var urun in Model)
                    {
                        <tr>
                            <td>@urun.UrunId</td>
                            <td>@urun.Musteri?.AdUnvan</td>
                            <td>@urun.UrunAdi</td>
                            <td>@urun.KrediMudiNo</td>
                            <td>@urun.TakipMiktari</td>
                            <td>@urun.DovizTipi</td>
                            <td>@urun.TakipTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@urun.Avukat?.Adi @urun.Avukat?.Soyadi</td>

                            <td class="text-center">
                                <a href="/Urun/Edit/@urun.UrunId"
                                   class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>

                                <a href="/Urun/Delete/@urun.UrunId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bu ürünü silmek istediğine emin misin?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            Kayıtlı ürün bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>